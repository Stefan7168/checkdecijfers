{
  "name": "checkdecijfers",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:test": "npm --prefix web run test",
    "web:typecheck": "npm --prefix web run typecheck",
    "web:ci": "npm --prefix web ci",
    "test": "vitest run",
    "test:ingestion": "vitest run tests/ingestion",
    "test:invariants": "vitest run tests/invariants",
    "test:benchmark": "vitest run tests/benchmark",
    "test:registry": "vitest run tests/registry",
    "test:query": "vitest run tests/query",
    "test:answer": "vitest run tests/answer",
    "test:chart": "vitest run tests/chart",
    "test:audit": "vitest run tests/audit",
    "test:billing": "vitest run tests/billing",
    "test:catalog": "vitest run tests/catalog",
    "test:db": "vitest run tests/db",
    "test:sources": "vitest run tests/sources",
    "test:websearch": "vitest run tests/websearch",
    "test:threads": "vitest run tests/threads",
    "benchmark:run": "node scripts/run-benchmark.ts",
    "benchmark:score": "node scripts/score-benchmark.mjs",
    "benchmark:run:live": "node --env-file=.env scripts/run-benchmark.ts --live",
    "benchmark:score:live": "node scripts/score-benchmark.mjs benchmark/audit-run-live.json --report benchmark/live-benchmark-report.json",
    "validation:run": "node --env-file=.env scripts/run-validation-pass.ts",
    "audit:experience": "node --env-file=.env scripts/run-experience-audit.ts",
    "audit:verify": "node --env-file=.env scripts/verify-audit-rows.ts",
    "gdpr:purge": "node --env-file=.env scripts/gdpr-purge.ts",
    "intent:eval": "node --env-file-if-exists=.env scripts/intent-eval.ts",
    "intent:record": "node --env-file-if-exists=.env scripts/intent-eval.ts --record",
    "onboarding-delivery:record": "node --env-file=.env scripts/onboarding-delivery-record.ts",
    "clarify:eval": "node --env-file-if-exists=.env scripts/clarify-eval.ts",
    "clarify:record": "node --env-file-if-exists=.env scripts/clarify-eval.ts --record",
    "followup:eval": "node --env-file-if-exists=.env scripts/followup-eval.ts",
    "followup:record": "node --env-file-if-exists=.env scripts/followup-eval.ts --record",
    "answer:eval": "node --env-file-if-exists=.env scripts/answer-eval.ts",
    "answer:record": "node --env-file-if-exists=.env scripts/answer-eval.ts --record",
    "tablefinder:eval": "node --env-file-if-exists=.env scripts/tablefinder-eval.ts",
    "tablefinder:record": "node --env-file-if-exists=.env scripts/tablefinder-eval.ts --record",
    "measurefit:eval": "node --env-file-if-exists=.env scripts/measurefit-eval.ts",
    "measurefit:record": "node --env-file-if-exists=.env scripts/measurefit-eval.ts --record",
    "semantic-check:eval": "node --env-file-if-exists=.env scripts/semantic-check-eval.ts",
    "semantic-check:record": "node --env-file-if-exists=.env scripts/semantic-check-eval.ts --record",
    "db:migrate": "node --env-file=.env src/db/migrate.ts",
    "ingest": "node --env-file=.env src/ingestion/cli.ts",
    "catalog:refresh": "node --env-file=.env src/catalog/cli.ts",
    "registry:apply": "node --env-file=.env src/registry/apply.ts",
    "pricing:apply": "node --env-file=.env src/billing/pricing-apply.ts",
    "fixtures:capture": "node scripts/capture-cbs-fixtures.ts",
    "fixtures:capture:catalog": "node scripts/capture-cbs-fixtures.ts --catalog"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.1",
    "pg": "^8.22.0",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  }
}
