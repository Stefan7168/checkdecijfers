# Copy this file to `.env` and fill in real values yourself.
# `.env` is gitignored — never commit it, never paste values into chat.
# Rotation steps per secret: docs/RUNBOOK.md, "Secrets register".

# Anthropic — console.anthropic.com -> API keys (set a monthly spend cap!)
ANTHROPIC_API_KEY=

# Supabase Postgres — dashboard -> Connect -> "Session pooler" connection string (URI).
# Use the Session pooler, NOT the direct connection: the direct db.*.supabase.co
# host is IPv6-only and unreachable from most home networks (measured 2026-07-02).
# Contains the database password; that password alone is never needed anywhere else.
DATABASE_URL=
